{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "xyz1001": {
      "npm": "@ai-sdk/openai",
      "options": {
        "baseURL": "{env:XYZ1001_API_URL}/v1"
      },
      "models": {
        "gpt-5.6-luna": {
          "name": "GPT 5.6 Luna"
        },
        "gpt-5.6-sol": {
          "name": "GPT 5.6 Sol"
        },
        "gpt-5.6-terra": {
          "name": "GPT 5.6 Terra"
        }
      }
    },
    "junhua": {
      "npm": "@ai-sdk/openai",
      "options": {
        "baseURL": "{env:JUNHUA_API_URL}/v1"
      },
      "models": {
        "gpt-image-2": {
          "name": "GPT Image 2"
        },
        "gpt-5.6-luna": {
          "name": "GPT 5.6 Luna"
        },
        "gpt-5.6-sol": {
          "name": "GPT 5.6 Sol"
        },
        "gpt-5.6-terra": {
          "name": "GPT 5.6 Terra"
        }
      }
    },
    "friendmlx": {
      "npm": "@ai-sdk/openai",
      "name": "Friend MLX",
      "options": {
        "baseURL": "http://120.48.144.58:8901/v1",
        "apiKey": "{env:FRIEND_MLX_API_KEY}"
      },
      "models": {
        "MLX-Qwen3.5-9B-Claude-4.6-Opus-Reasoning-Distilled-4bit": {
          "name": "MLX Qwen3.5 9B Distilled"
        }
      }
    }
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "chrome-devtools-mcp@latest", "--autoConnect"]
    }
  },
  "plugin": [
    "superpowers@git+https://github.com/obra/superpowers.git",
    "oh-my-opencode-slim"
  ]
}
